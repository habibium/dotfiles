[user]
	name = habibium
	email = habib.prodev@gmail.com

[init]
	defaultBranch = main

[color]
	ui = auto

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between files
    side-by-side = true # optional side-by-side view
    line-numbers = true

[merge]
    conflictStyle = zdiff3