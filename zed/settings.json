{
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware"
  },
  "colorize_brackets": true,
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "default_width": 320,
    "git_status_indicator": true,
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "sort_by_path": true
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "base_keymap": "VSCode",
  "vertical_scroll_margin": 4.0,
  "gutter": {
    "line_numbers": true
  },
  "minimap": {
    "show": "never"
  },
  "file_types": {
    "tailwindcss": ["*.css"]
  },
  "soft_wrap": "editor_width",
  "disable_ai": true,
  "theme": {
    "mode": "system",
    "light": "GitHub Light",
    "dark": "GitHub Dark"
  },
  "icon_theme": "Material Icon Theme",
  "tabs": {
    "file_icons": true
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never"
  },
  "which_key": {
    "enabled": true
  },
  "sticky_scroll": {
    "enabled": true
  },
  "relative_line_numbers": "enabled",
  "buffer_font_fallbacks": ["Monaco"],
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_features": {
    "calt": false
  },
  "buffer_font_size": 14.0,
  "language_servers": ["!eslint", "!typescript-language-server", "..."],
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave"
        }
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    },
    "tinymist": {
      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/$name"
      }
    }
  },
  "languages": {
    "CSS": {
      "soft_wrap": "editor_width",
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "language_servers": ["tailwindcss-intellisense-css", "!vscode-css-language-server", "..."],
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "GraphQL": {
      "soft_wrap": "editor_width",
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Handlebars": {
      "soft_wrap": "editor_width",
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "soft_wrap": "editor_width",
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "soft_wrap": "editor_width",
      "format_on_save": "on",
      "language_servers": ["oxlint", "!eslint", "!typescript-language-server", "..."],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "JSON": {
